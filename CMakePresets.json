{
  "version": 3,
  "configurePresets": [
    {
      "name": "default",
      "displayName": "Default (vcpkg)",
      "description": "Build with vcpkg dependency management",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "/home/uday/vcpkg/scripts/buildsystems/vcpkg.cmake",
        "CMAKE_BUILD_TYPE": "Debug",
        "USE_MIMALLOC": "OFF"
      }
    },
    {
      "name": "release",
      "displayName": "Release (vcpkg + mimalloc)",
      "description": "Optimized release build with -O3, -march=native, LTO, and mimalloc",
      "inherits": "default",
      "binaryDir": "${sourceDir}/build-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "USE_MIMALLOC": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "default",
      "configurePreset": "default"
    },
    {
      "name": "release",
      "configurePreset": "release"
    }
  ]
}
